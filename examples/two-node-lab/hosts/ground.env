# asterisk-a -- node 1, the ground station / NM manager.
# Runs the full stack: ion, nm-agent, nm-mgr, nm2munin bridge, dummy-traffic,
# plus the Munin master + munin-node.
source "$(dirname "${BASH_SOURCE[0]}")/common.env"

ROLE=manager

NODE_NBR=1
LOCAL_IP=192.168.122.10
PEER_NODE=2
PEER_IP=192.168.122.197

AGENT_EID=ipn:1.2
WM_SIZE=20000000

# Agents this manager polls, and the EID=port map the bridge serves to Munin.
NM_AGENTS="ipn:1.2 ipn:2.1"
BRIDGE_MAP="ipn:1.2=4950 ipn:2.1=4951"
