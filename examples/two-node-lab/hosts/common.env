# Shared settings for every node in the nm2munin DTN lab.
# Per-host files (ground.env / remote.env) source this and override as needed.

ION_USER=iondtn
ION_GROUP=iondtn

# UDP convergence-layer port (same on both ends of the bidirectional link)
CLA_PORT=4556

# NM manager EID (the ground station collecting reports)
MGR_EID=ipn:1.1

# Where the rendered nm2munin daemons get installed on the manager host
INSTALL_DIR=/opt/nm2munin

# nm-mgr poll cadence (seconds) and dummy-traffic shape
NM_INTERVAL=30
DUMMY_TICK=20
DUMMY_MAXRATE=90
