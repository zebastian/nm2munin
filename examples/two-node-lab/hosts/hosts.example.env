# Template for adding a new node. Copy to hosts/<name>.env and edit.
source "$(dirname "${BASH_SOURCE[0]}")/common.env"

# ROLE is either "manager" (ground station: full stack + Munin) or
# "agent" (remote: ion + nm-agent only).
ROLE=agent

NODE_NBR=3
LOCAL_IP=192.0.2.3
PEER_NODE=1
PEER_IP=192.0.2.1

AGENT_EID=ipn:3.1
WM_SIZE=33554432

# manager-only knobs (ignored for ROLE=agent):
#NM_AGENTS="ipn:1.2 ipn:2.1 ipn:3.1"
#BRIDGE_MAP="ipn:1.2=4950 ipn:2.1=4951 ipn:3.1=4952"
