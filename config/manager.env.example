# manager.env -- configuration for an nm2munin manager/bridge deployment.
# Copy to manager.env and edit for your topology. This file is the ONLY place
# that knows which agents you monitor; the daemons and units are generic.
#
# Prerequisite (out of scope for this project): the host already runs an ION
# node plus an `nm_agent`/`nm_mgr`-capable stack. See examples/two-node-lab for
# one way to stand that up.

# System user/group the bridge + manager run as (must own /var/lib/nm).
ION_USER=iondtn
ION_GROUP=iondtn

# Where bridge.py + nm_mgr_run.py are installed and run from.
INSTALL_DIR=/opt/nm2munin

# EID of the local NM manager (nm_mgr -A argument).
MGR_EID=ipn:1.1

# Space-separated EIDs of the agents this manager polls for reports.
NM_AGENTS="ipn:1.2 ipn:2.1"

# EID=port map the bridge exposes to the Munin master, one local TCP port per
# agent. Munin's munin-conf.d/dtn.conf is generated from this. Add an entry per
# agent in NM_AGENTS, each on a free port.
BRIDGE_MAP="ipn:1.2=4950 ipn:2.1=4951"

# Manager poll cadence, seconds.
NM_INTERVAL=30

# Address the bridge binds its per-EID ports on (the Munin master is local).
NM2MUNIN_BIND=127.0.0.1
